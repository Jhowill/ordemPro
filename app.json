{
  "expo": {
    "name": "OrdemPro",
    "slug": "ordempro",
    "scheme": "ordempro",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./Icons/02_expo_assets_ready/icon.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "splash": {
      "image": "./Icons/02_expo_assets_ready/splash-light-1242x2436.png",
      "resizeMode": "cover",
      "backgroundColor": "#F4F6F8",
      "dark": {
        "image": "./Icons/02_expo_assets_ready/splash-dark-1242x2436.png",
        "resizeMode": "cover",
        "backgroundColor": "#0B1120"
      }
    },
    "ios": {
      "bundleIdentifier": "com.jwmdevcreator.ordempro",
      "buildNumber": "1",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Permita tirar fotos de equipamentos, servicos e assinaturas.",
        "NSPhotoLibraryUsageDescription": "Permita selecionar logos, fotos das OS e assinaturas.",
        "NSPhotoLibraryAddUsageDescription": "Permita salvar imagens usadas pelo OrdemPro."
      }
    },
    "android": {
      "package": "com.jwmdevcreator.ordempro",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./Icons/02_expo_assets_ready/adaptive-icon.png",
        "backgroundImage": "./Icons/02_expo_assets_ready/adaptive-background.png",
        "monochromeImage": "./Icons/02_expo_assets_ready/notification-icon.png",
        "backgroundColor": "#1E4FD7"
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permita selecionar logos, fotos das OS e assinaturas.",
          "cameraPermission": "Permita tirar fotos de equipamentos, servicos e assinaturas.",
          "microphonePermission": false
        }
      ],
      "expo-font"
    ],
    "web": {
      "favicon": "./Icons/02_expo_assets_ready/favicon.png"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f871d6ad-c29e-4e8a-9230-2674ca19688f"
      }
    }
  }
}
